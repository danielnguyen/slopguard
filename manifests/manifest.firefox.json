{
  "manifest_version": 2,
  "name": "SlopGuard",
  "version": "0.1.0",
  "description": "Highlights low-transparency, engagement-driven YouTube content.",
  "permissions": ["storage", "https://www.youtube.com/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
